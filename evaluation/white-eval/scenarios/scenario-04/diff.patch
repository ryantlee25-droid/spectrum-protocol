+import { Request, Response } from 'express';
+import { db } from '../db';
+import { Order, OrderItem } from '../types';
+
+/**
+ * Returns dashboard summary data for the current user.
+ * Includes order history with enriched product details.
+ * GET /api/dashboard
+ */
+export async function getDashboard(req: Request, res: Response): Promise<void> {
+  const userId = req.user!.id;
+
+  // Fetch user's orders
+  const orders = await db.orders.find({ userId, status: 'completed' });
+
+  // Enrich each order with product details
+  const enrichedOrders = [];
+  for (const order of orders) {
+    const enrichedItems = [];
+    for (const item of order.items) {
+      const product = await db.products.findById(item.productId);
+      enrichedItems.push({
+        ...item,
+        productName: product.name,
+        productImageUrl: product.imageUrl,
+        currentPrice: product.price,
+      });
+    }
+    enrichedOrders.push({ ...order, items: enrichedItems });
+  }
+
+  res.json({ orders: enrichedOrders });
+}
+
+/**
+ * Returns order count and total spend for the current user.
+ * Used for the stats bar at the top of the dashboard.
+ * GET /api/dashboard/stats
+ */
+export async function getDashboardStats(req: Request, res: Response): Promise<void> {
+  const userId = req.user!.id;
+
+  const orders = await db.orders.find({ userId, status: 'completed' });
+
+  const totalSpend = orders.reduce((sum: number, order: Order) => sum + order.total, 0);
+  const orderCount = orders.length;
+
+  res.json({ orderCount, totalSpend });
+}
+
+/**
+ * Returns the most recently viewed products for the current user.
+ * GET /api/dashboard/recently-viewed
+ */
+export async function getRecentlyViewed(req: Request, res: Response): Promise<void> {
+  const userId = req.user!.id;
+
+  const viewHistory = await db.viewHistory.find(
+    { userId },
+    { sort: { viewedAt: -1 }, limit: 10 }
+  );
+
+  const products = [];
+  for (const view of viewHistory) {
+    const product = await db.products.findById(view.productId);
+    products.push({
+      ...product,
+      lastViewedAt: view.viewedAt,
+    });
+  }
+
+  res.json({ products });
+}
+
+/**
+ * Marks all unread notifications as read for the current user.
+ * POST /api/dashboard/notifications/read-all
+ */
+export async function markAllNotificationsRead(req: Request, res: Response): Promise<void> {
+  const userId = req.user!.id;
+
+  await db.notifications.updateMany(
+    { userId, read: false },
+    { $set: { read: true, readAt: new Date() } }
+  );
+
+  res.json({ success: true });
+}
