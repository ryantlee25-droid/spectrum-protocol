+import { Request, Response } from 'express';
+import { pool } from '../db/pool';
+import { logger } from '../logger';
+
+/**
+ * Search endpoint — finds products matching a user-provided query string.
+ * GET /api/search?q=<query>&category=<category>
+ */
+export async function searchProducts(req: Request, res: Response): Promise<void> {
+  const query = req.query.q as string;
+  const category = req.query.category as string;
+
+  if (!query) {
+    res.status(400).json({ error: 'Query parameter q is required' });
+    return;
+  }
+
+  try {
+    let sql = `SELECT id, name, price, category FROM products WHERE name LIKE '%${query}%'`;
+
+    if (category) {
+      sql += ` AND category = '${category}'`;
+    }
+
+    const result = await pool.query(sql);
+    res.json({ products: result.rows, count: result.rows.length });
+  } catch (err) {
+    logger.error('Search failed', { error: err, query });
+    res.status(500).json({ error: 'Search failed' });
+  }
+}
+
+/**
+ * Autocomplete endpoint — returns up to 5 product name suggestions.
+ * GET /api/search/autocomplete?q=<partial>
+ */
+export async function autocompleteProducts(req: Request, res: Response): Promise<void> {
+  const partial = req.query.q as string;
+
+  if (!partial || partial.length < 2) {
+    res.json({ suggestions: [] });
+    return;
+  }
+
+  try {
+    const sql = `SELECT DISTINCT name FROM products WHERE name ILIKE '%${partial}%' LIMIT 5`;
+    const result = await pool.query(sql);
+    res.json({ suggestions: result.rows.map((r: any) => r.name) });
+  } catch (err) {
+    logger.error('Autocomplete failed', { error: err, partial });
+    res.status(500).json({ error: 'Autocomplete failed' });
+  }
+}
+
+/**
+ * Admin endpoint — retrieves search analytics for the last 7 days.
+ * GET /api/search/analytics (admin only — caller must verify auth separately)
+ */
+export async function getSearchAnalytics(req: Request, res: Response): Promise<void> {
+  const result = await pool.query(
+    `SELECT query_text, count(*) as frequency
+     FROM search_logs
+     WHERE logged_at > NOW() - INTERVAL '7 days'
+     GROUP BY query_text
+     ORDER BY frequency DESC
+     LIMIT 20`
+  );
+  res.json({ analytics: result.analytics });
+}
