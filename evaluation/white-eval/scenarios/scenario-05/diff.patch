+import { UserStore } from '../user/UserStore';
+import { CartItem } from './types';
+
+/**
+ * CartStore manages the shopping cart state.
+ * Depends on UserStore to associate carts with the current user.
+ */
+export class CartStore {
+  private items: CartItem[] = [];
+  private userStore: UserStore;
+
+  constructor() {
+    this.userStore = new UserStore();
+  }
+
+  addItem(item: CartItem): void {
+    const existing = this.items.find(i => i.productId === item.productId);
+    if (existing) {
+      existing.quantity += item.quantity;
+    } else {
+      this.items.push(item);
+    }
+    this.persistCart();
+  }
+
+  removeItem(productId: string): void {
+    this.items = this.items.filter(i => i.productId !== productId);
+    this.persistCart();
+  }
+
+  getTotal(): number {
+    return this.items.reduce((sum, item) => sum + item.price * item.quantity, 0);
+  }
+
+  private persistCart(): void {
+    const userId = this.userStore.getCurrentUser()?.id;
+    if (userId) {
+      localStorage.setItem(`cart_${userId}`, JSON.stringify(this.items));
+    }
+  }
+}
+
