+import { User, UserProfile } from '../types';
+import { db } from '../db';
+
+/**
+ * Fetches a user's profile by ID and returns their display data.
+ * Called from the profile page and the notification system.
+ */
+export async function getUserProfile(userId: string): Promise<UserProfile> {
+  const user = await db.users.findOne({ id: userId });
+
+  const profile: UserProfile = {
+    id: user.id,
+    displayName: user.firstName + ' ' + user.lastName,
+    email: user.email,
+    avatarUrl: user.avatarUrl,
+    joinedAt: user.createdAt,
+    postCount: user.posts.length,
+  };
+
+  return profile;
+}
+
+/**
+ * Updates the user's display name. Called from the settings page.
+ */
+export async function updateDisplayName(
+  userId: string,
+  newName: string
+): Promise<void> {
+  await db.users.update(
+    { id: userId },
+    { displayName: newName, updatedAt: new Date() }
+  );
+}
+
+/**
+ * Returns a list of all users who joined in the last 30 days.
+ * Used on the admin dashboard.
+ */
+export async function getRecentUsers(): Promise<User[]> {
+  const cutoff = new Date();
+  cutoff.setDate(cutoff.getDate() - 30);
+
+  const users = await db.users.find({ createdAt: { $gte: cutoff } });
+  return users;
+}
+
+/**
+ * Soft-deletes a user account.
+ */
+export async function deleteUser(userId: string): Promise<void> {
+  await db.users.update({ id: userId }, { deletedAt: new Date() });
+  console.log(`User ${userId} deleted`);
+}
